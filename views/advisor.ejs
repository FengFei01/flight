  <meta property="og:title" content="AI 调参顾问 - FlightForge">
  <meta property="og:description" content="Free browser-based AI PID tuning advisor for Betaflight. Runs locally, no data uploaded. Diagnose flight issues and get tuning recommendations.">
  <meta property="og:url" content="https://flight-forge.polsia.app/advisor">
  <meta property="og:type" content="website">
  <meta property="og:image" content="https://pub-629428d185ca4960a0a73c850d32294b.r2.dev/generated-images/company_180433/86517f03-cf67-473f-baec-62b4ee3236a3.jpg">
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary_large_image">
  <meta name="twitter:title" content="AI PID Tuning Advisor - FlightForge">
  <meta name="twitter:description" content="Browser-local AI advisor for Betaflight PID tuning. Free, offline-capable, no data leaves your machine.">
  <meta name="twitter:image" content="https://pub-629428d185ca4960a0a73c850d32294b.r2.dev/generated-images/company_180433/86517f03-cf67-473f-baec-62b4ee3236a3.jpg">
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&family=Inter:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/theme.css">
  <link rel="stylesheet" href="/css/app.css">
  <link rel="stylesheet" href="/css/advisor.css">
</head>
<body>
  <!-- Nav -->
  <nav class="app-nav">
    <div class="nav-inner">
      <a href="/" class="nav-logo">FlightForge</a>
      <div class="nav-links">
        <a href="/analyze" class="nav-link">Analyze</a>
        <a href="/advisor" class="nav-link active">AI 顾问</a>
        <a href="#" class="nav-link" onclick="document.getElementById('feedbackModal').style.display='flex';return false;">反馈</a>
      </div>
    </div>
  </nav>

  <main class="app-main advisor-main">
    <div class="advisor-container">
      <!-- Header -->
      <div class="advisor-header">
        <div class="hero-badge" style="margin-bottom: 12px">AI 调参顾问</div>
        <h1>PID 调参 AI 助手</h1>
        <p class="advisor-sub">基于浏览器本地运行的 AI 模型，免费、离线可用。为你的飞机提供专业的 PID 调参建议。</p>
      </div>

      <!-- Analysis Context Banner (shown when navigated from results page) -->
      <div id="advisorContextBanner" class="advisor-context-banner" style="display:none">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="var(--accent)" stroke-width="2"><path d="M22 12h-4l-3 9L9 3l-3 9H2"/></svg>
        <div>
          <span id="advisorContextText">已加载分析数据</span>
          <div id="advisorContextTags" class="advisor-context-tags"></div>
        </div>
      </div>

      <!-- Engine Status -->
      <div id="engineStatus" class="engine-status engine-status-idle">
        <div class="engine-status-row">
          <span id="engineStatusText">⏸️ 点击下方按钮初始化 AI 模型</span>
          <button type="button" id="initEngineBtn" class="btn-ble btn-ble-apply">
            🧠 加载 AI 模型
          </button>
        </div>
        <div id="engineProgress" class="engine-progress" style="display:none">
          <div id="engineProgressFill" class="engine-progress-fill" style="width:0%"></div>
        </div>
      </div>

      <!-- Backend Indicator — shows local vs cloud mode -->
      <div id="backendIndicator" class="backend-indicator"></div>
      <div id="backendDetail" class="backend-detail" style="display:none"></div>

      <!-- Chat Area -->
      <div class="chat-container">
        <div id="chatMessages" class="chat-messages">
          <!-- Welcome message -->
          <div class="chat-bubble chat-assistant">
            <div class="chat-avatar chat-avatar-assistant">🤖</div>
            <div class="chat-body">
              <strong>你好！我是 FlightForge AI 调参顾问。</strong><br><br>
              我可以帮你解决 Betaflight PID 调参问题：<br>
              • 诊断飞行问题（抖动、过冲、漂移等）<br>
              • 推荐 PID 参数调整方案<br>
              • 解释各参数的作用和影响<br>
              • 根据你的机型给出参考值<br><br>
              <em>首次使用需下载 AI 模型 (~1GB)，下载后会缓存到浏览器，后续秒开。</em>
            </div>
          </div>
        </div>

        <!-- Preset Questions -->
        <div id="presetBtns" class="preset-wrap">
          <!-- Preset buttons rendered by advisor-chat.js -->
        </div>

        <!-- Input Area -->
        <div class="chat-input-wrap">
          <textarea id="chatInput" class="chat-input" placeholder="描述你的飞行问题..." rows="1" disabled></textarea>
          <button type="button" id="sendBtn" class="chat-send-btn" disabled>
            <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2">
              <line x1="22" y1="2" x2="11" y2="13"></line>
              <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
            </svg>
          </button>
        </div>
      </div>

      <!-- Info Footer -->
      <div class="advisor-info">
        <div class="advisor-info-item">
          <span>🔒</span>
          <span>完全本地运行，数据不上传</span>
        </div>
        <div class="advisor-info-item">
          <span>📶</span>
          <span>模型缓存后离线可用</span>
        </div>
        <div class="advisor-info-item">
          <span>🆓</span>
          <span>免费使用，无次数限制</span>
        </div>
      </div>
    </div>
  </main>

  <!-- Load analysis context from sessionStorage if navigated from results page -->
  <script>
    (function () {
      try {
        var ctx = sessionStorage.getItem('ff_advisor_context');
        if (ctx) {
          window._ffAdvisorContext = JSON.parse(ctx);
          // Render context banner
          var banner = document.getElementById('advisorContextBanner');
          var tagsEl = document.getElementById('advisorContextTags');
          var textEl = document.getElementById('advisorContextText');
          if (banner && window._ffAdvisorContext && window._ffAdvisorContext.currentPIDs) {
            banner.style.display = 'flex';
            textEl.textContent = '已加载 BBL 分析数据 — AI 将基于你的实际飞行数据回答';
            var tags = [];
            if (window._ffAdvisorContext.firmware) tags.push('固件 ' + window._ffAdvisorContext.firmware);
            if (window._ffAdvisorContext.flightStyle) {
              var styleNames = { freestyle: '花飞', racing: '竞速', cinematic: '航拍', longrange: '远航' };
              tags.push('风格 ' + (styleNames[window._ffAdvisorContext.flightStyle] || window._ffAdvisorContext.flightStyle));
            }
            if (window._ffAdvisorContext.flightScore) tags.push('评分 ' + window._ffAdvisorContext.flightScore.score);
            if (window._ffAdvisorContext.motorHealth) tags.push('电机 ' + window._ffAdvisorContext.motorHealth.overall.score);
            tags.push('PID ✓');
            tags.push('滤波 ✓');
            if (tagsEl) {
              tagsEl.innerHTML = tags.map(function(t) { return '<span class="advisor-context-tag">' + t + '</span>'; }).join('');
            }
          }
        }
      } catch (_) {}
    })();
  </script>

  <script src="/js/fc-transport.js"></script>
  <script src="/js/msp-client.js"></script>
  <script src="/js/fc-connection-manager.js"></script>
  <script src="/js/webllm-engine.js"></script>
  <script src="/js/pid-knowledge.js"></script>
  <script src="/js/advisor-chat.js"></script>
  <script src="/js/advisor-analytics.js"></script>
<!-- Feedback Modal -->
<div id="feedbackModal" style="display:none; position:fixed; inset:0; z-index:200; background:rgba(10,14,23,0.88); backdrop-filter:blur(8px); align-items:center; justify-content:center;">
  <div style="background:var(--bg-card); border:1px solid rgba(0,212,255,0.12); border-radius:var(--radius-sm); padding:32px; max-width:480px; width:90%; position:relative;">
    <button onclick="document.getElementById('feedbackModal').style.display='none'" style="position:absolute;top:12px;right:16px;background:none;border:none;color:var(--fg-muted);font-size:20px;cursor:pointer;">&times;</button>
    <h3 style="font-family:var(--font-display);font-size:18px;font-weight:700;margin-bottom:4px;">反馈 / Feedback</h3>
    <p style="font-size:12px;color:var(--fg-dim);margin-bottom:20px;">遇到问题或有建议？请告诉我们。</p>
    <form id="feedbackForm">
      <select id="fbType" name="type" required style="width:100%;background:var(--bg-elevated);border:1px solid rgba(0,212,255,0.12);border-radius:4px;color:var(--fg);font-family:var(--font-mono);font-size:13px;padding:8px 10px;margin-bottom:12px;box-sizing:border-box;">
        <option value="" disabled selected>选择反馈类型...</option>
        <option value="问题反馈">问题反馈 / Bug Report</option>
        <option value="功能建议">功能建议 / Feature Request</option>
        <option value="使用咨询">使用咨询 / Question</option>
        <option value="其他">其他 / Other</option>
      </select>
      <textarea id="fbContent" name="content" required minlength="10" maxlength="2000" rows="4" placeholder="请描述你的问题或建议..." style="width:100%;background:var(--bg-elevated);border:1px solid rgba(0,212,255,0.12);border-radius:4px;color:var(--fg);font-family:var(--font-mono);font-size:13px;padding:10px;resize:vertical;margin-bottom:12px;box-sizing:border-box;"></textarea>
      <input id="fbContact" name="contact_info" type="text" maxlength="200" placeholder="邮箱或微信 (选填)" style="width:100%;background:var(--bg-elevated);border:1px solid rgba(0,212,255,0.12);border-radius:4px;color:var(--fg);font-family:var(--font-mono);font-size:13px;padding:8px 10px;margin-bottom:12px;box-sizing:border-box;">
      <div style="position:absolute;left:-9999px;" aria-hidden="true">
        <input name="website" tabindex="-1" autocomplete="off">
      </div>
      <label style="display:block;font-size:12px;color:var(--fg-dim);margin-bottom:6px;">截图 (选填)</label>
      <input id="fbScreenshot" name="screenshot" type="file" accept="image/*" style="font-size:12px;color:var(--fg-dim);margin-bottom:12px;">
      <div id="captchaRow" style="margin-bottom:12px;display:flex;align-items:center;gap:8px;">
        <span style="font-size:13px;color:var(--fg);" id="captchaQ"></span>
        <input id="captchaAns" type="number" placeholder="?" style="width:60px;background:var(--bg-elevated);border:1px solid rgba(0,212,255,0.12);border-radius:4px;color:var(--fg);font-family:var(--font-mono);font-size:13px;padding:6px 8px;box-sizing:border-box;" required>
      </div>
      <div id="fbMsg" style="font-size:12px;margin-bottom:12px;display:none;"></div>
      <button type="submit" id="fbSubmitBtn" style="background:var(--accent);color:#000;padding:10px 24px;border:none;border-radius:4px;font-family:var(--font-mono);font-weight:700;font-size:13px;cursor:pointer;transition:opacity 0.2s;">提交反馈 / Submit</button>
    </form>
  </div>
</div>
<script>
(function(){
  var form = document.getElementById('feedbackForm');
  var btn = document.getElementById('fbSubmitBtn');
  var msg = document.getElementById('fbMsg');
  var captchaQ = document.getElementById('captchaQ');
  var captchaAns = document.getElementById('captchaAns');
  var a, b;

  function genCaptcha() {
    a = Math.floor(Math.random() * 20) + 1;
    b = Math.floor(Math.random() * 20) + 1;
    captchaQ.textContent = a + ' + ' + b + ' = ?';
    captchaAns.value = '';
  }
  genCaptcha();

  var cooldownTimer = null;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var content = document.getElementById('fbContent').value.trim();
    if (!content) return;

    if (content.length < 10) {
      msg.style.color = 'var(--danger)';
      msg.textContent = '反馈内容至少需要10个字符。';
      msg.style.display = 'block';
      return;
    }

    if (parseInt(captchaAns.value, 10) !== a + b) {
      msg.style.color = 'var(--danger)';
      msg.textContent = '验证码错误，请重试。';
      msg.style.display = 'block';
      genCaptcha();
      return;
    }

    btn.disabled = true;
    btn.textContent = '提交中...';
    msg.style.display = 'none';
    var fd = new FormData();
    fd.append('content', content);
    fd.append('contact_info', document.getElementById('fbContact').value.trim());
    fd.append('type', document.getElementById('fbType').value);
    var ws = form.querySelector('[name="website"]');
    if (ws) fd.append('website', ws.value);
    var file = document.getElementById('fbScreenshot').files[0];
    if (file) fd.append('screenshot', file);
    fetch('/api/feedback', { method: 'POST', body: fd })
      .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
      .then(function(res) {
        if (res.ok) {
          msg.style.color = 'var(--success)';
          msg.textContent = '感谢反馈！我们会尽快处理。';
          msg.style.display = 'block';
          form.reset();
          genCaptcha();
          var sec = 60;
          btn.textContent = sec + '秒后可再次提交';
          cooldownTimer = setInterval(function() {
            sec--;
            if (sec <= 0) {
              clearInterval(cooldownTimer);
              btn.disabled = false;
              btn.textContent = '提交反馈 / Submit';
            } else {
              btn.textContent = sec + '秒后可再次提交';
            }
          }, 1000);
          setTimeout(function() { document.getElementById('feedbackModal').style.display = 'none'; msg.style.display = 'none'; }, 2000);
        } else {
          msg.style.color = 'var(--danger)';
          msg.textContent = res.data.error || '提交失败，请稍后重试。';
          msg.style.display = 'block';
          btn.disabled = false;
          btn.textContent = '提交反馈 / Submit';
          genCaptcha();
        }
      })
      .catch(function() {
        msg.style.color = 'var(--danger)';
        msg.textContent = '网络错误，请稍后重试。';
        msg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = '提交反馈 / Submit';
        genCaptcha();
      });
  });

  document.querySelectorAll('[onclick*="feedbackModal"]').forEach(function(el) {
    el.addEventListener('click', function() { genCaptcha(); });
  });
})();
</script>
