<div id="feedbackModal" style="display:none; position:fixed; inset:0; z-index:200; background:rgba(13,13,15,0.88); backdrop-filter:blur(8px); align-items:center; justify-content:center;">
  <div style="background:var(--bg2); border:1px solid var(--border); border-radius:8px; padding:32px; max-width:480px; width:90%; position:relative;">
    <button onclick="document.getElementById('feedbackModal').style.display='none'" style="position:absolute;top:12px;right:16px;background:none;border:none;color:var(--text2);font-size:20px;cursor:pointer;">&times;</button>
    <h3 style="font-family:var(--font-head);font-size:18px;font-weight:700;margin-bottom:4px;">反馈 / Feedback</h3>
    <p style="font-size:12px;color:var(--text2);margin-bottom:20px;">遇到问题或有建议？请告诉我们。</p>
    <form id="feedbackForm">
      <select id="fbType" name="type" required style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--font-mono);font-size:13px;padding:8px 10px;margin-bottom:12px;box-sizing:border-box;">
        <option value="" disabled selected>选择反馈类型...</option>
        <option value="问题反馈">问题反馈 / Bug Report</option>
        <option value="功能建议">功能建议 / Feature Request</option>
        <option value="使用咨询">使用咨询 / Question</option>
        <option value="其他">其他 / Other</option>
      </select>
      <textarea id="fbContent" name="content" required minlength="10" maxlength="2000" rows="4" placeholder="请描述你的问题或建议..." style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--font-mono);font-size:13px;padding:10px;resize:vertical;margin-bottom:12px;box-sizing:border-box;"></textarea>
      <input id="fbContact" name="contact_info" type="text" maxlength="200" placeholder="邮箱或微信 (选填)" style="width:100%;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--font-mono);font-size:13px;padding:8px 10px;margin-bottom:12px;box-sizing:border-box;">
      <div style="position:absolute;left:-9999px;" aria-hidden="true">
        <input name="website" tabindex="-1" autocomplete="off">
      </div>
      <label style="display:block;font-size:12px;color:var(--text2);margin-bottom:6px;">截图 (选填)</label>
      <input id="fbScreenshot" name="screenshot" type="file" accept="image/*" style="font-size:12px;color:var(--text2);margin-bottom:12px;">
      <div id="captchaRow" style="margin-bottom:12px;display:flex;align-items:center;gap:8px;">
        <span style="font-size:13px;color:var(--text);" id="captchaQ"></span>
        <input id="captchaAns" type="number" placeholder="?" style="width:60px;background:var(--bg3);border:1px solid var(--border);border-radius:4px;color:var(--text);font-family:var(--font-mono);font-size:13px;padding:6px 8px;box-sizing:border-box;" required>
      </div>
      <div id="fbMsg" style="font-size:12px;margin-bottom:12px;display:none;"></div>
      <button type="submit" id="fbSubmitBtn" style="background:var(--accent);color:#000;padding:10px 24px;border:none;border-radius:4px;font-family:var(--font-mono);font-weight:700;font-size:13px;cursor:pointer;transition:opacity 0.2s;">提交反馈 / Submit</button>
    </form>
  </div>
</div>
<script>
(function(){
  var form = document.getElementById('feedbackForm');
  var btn = document.getElementById('fbSubmitBtn');
  var msg = document.getElementById('fbMsg');
  var captchaQ = document.getElementById('captchaQ');
  var captchaAns = document.getElementById('captchaAns');
  var a, b;

  function genCaptcha() {
    a = Math.floor(Math.random() * 20) + 1;
    b = Math.floor(Math.random() * 20) + 1;
    captchaQ.textContent = a + ' + ' + b + ' = ?';
    captchaAns.value = '';
  }
  genCaptcha();

  var cooldownTimer = null;

  form.addEventListener('submit', function(e) {
    e.preventDefault();
    var content = document.getElementById('fbContent').value.trim();
    if (!content) return;

    if (content.length < 10) {
      msg.style.color = '#ff6b35';
      msg.textContent = '反馈内容至少需要10个字符。';
      msg.style.display = 'block';
      return;
    }

    if (parseInt(captchaAns.value, 10) !== a + b) {
      msg.style.color = '#ff6b35';
      msg.textContent = '验证码错误，请重试。';
      msg.style.display = 'block';
      genCaptcha();
      return;
    }

    btn.disabled = true;
    btn.textContent = '提交中...';
    msg.style.display = 'none';
    var fd = new FormData();
    fd.append('content', content);
    fd.append('contact_info', document.getElementById('fbContact').value.trim());
    fd.append('type', document.getElementById('fbType').value);
    var ws = form.querySelector('[name="website"]');
    if (ws) fd.append('website', ws.value);
    var file = document.getElementById('fbScreenshot').files[0];
    if (file) fd.append('screenshot', file);
    fetch('/api/feedback', { method: 'POST', body: fd })
      .then(function(r) { return r.json().then(function(d) { return { ok: r.ok, data: d }; }); })
      .then(function(res) {
        if (res.ok) {
          msg.style.color = '#a8ff3e';
          msg.textContent = '感谢反馈！我们会尽快处理。';
          msg.style.display = 'block';
          form.reset();
          genCaptcha();
          var sec = 60;
          btn.textContent = sec + '秒后可再次提交';
          cooldownTimer = setInterval(function() {
            sec--;
            if (sec <= 0) {
              clearInterval(cooldownTimer);
              btn.disabled = false;
              btn.textContent = '提交反馈 / Submit';
            } else {
              btn.textContent = sec + '秒后可再次提交';
            }
          }, 1000);
          setTimeout(function() { document.getElementById('feedbackModal').style.display = 'none'; msg.style.display = 'none'; }, 2000);
        } else {
          msg.style.color = '#ff6b35';
          msg.textContent = res.data.error || '提交失败，请稍后重试。';
          msg.style.display = 'block';
          btn.disabled = false;
          btn.textContent = '提交反馈 / Submit';
          genCaptcha();
        }
      })
      .catch(function() {
        msg.style.color = '#ff6b35';
        msg.textContent = '网络错误，请稍后重试。';
        msg.style.display = 'block';
        btn.disabled = false;
        btn.textContent = '提交反馈 / Submit';
        genCaptcha();
      });
  });

  document.querySelectorAll('[onclick*="feedbackModal"]').forEach(function(el) {
    el.addEventListener('click', function() { genCaptcha(); });
  });
})();
</script>
