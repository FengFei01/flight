    <div class="upload-container">
      <div class="upload-header">
        <div class="hero-badge" style="margin-bottom: 16px">LOG ANALYZER</div>
        <h1>Upload Your Blackbox Log</h1>
        <p class="upload-sub">Drop a <span class="mono">.BBL</span> file from your flight controller. FlightForge analyzes gyro data, motor output, and error signals to recommend optimized PID values.</p>
      </div>

      <% if (error) { %>
        <div class="error-banner">
          <svg viewBox="0 0 24 24" width="20" height="20" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span><%= error %></span>
        </div>
      <% } %>

      <form id="uploadForm" action="/analyze" method="POST" enctype="multipart/form-data">
        <div id="dropZone" class="drop-zone">
          <div class="drop-icon">
            <svg viewBox="0 0 64 64" width="64" height="64" fill="none">
              <rect x="8" y="16" width="48" height="40" rx="4" stroke="#00d4ff" stroke-width="2" opacity="0.5"/>
              <path d="M32 8 L32 36" stroke="#00d4ff" stroke-width="2.5" stroke-linecap="round"/>
              <path d="M22 18 L32 8 L42 18" stroke="#00d4ff" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </div>
          <p class="drop-label">Drag & drop your <strong>.BBL</strong> file here</p>
          <p class="drop-hint">or click to browse • Max 50MB</p>
          <input type="file" id="bblInput" name="bblFile" accept=".bbl,.bfl" hidden>
        </div>

        <div id="filePreview" class="file-preview" style="display:none">
