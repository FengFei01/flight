<script>
(function() {
  // Stable user ID
  var uid = localStorage.getItem('ff_user_id');
  if (!uid) {
    uid = 'u_' + Date.now().toString(36) + '_' + Math.random().toString(36).substr(2, 8);
    localStorage.setItem('ff_user_id', uid);
  }

  // Check current usage status and show badge
  fetch('/api/payments/usage', { headers: { 'x-user-id': uid } })
    .then(function(r) { return r.ok ? r.json() : null; })
    .then(function(status) {
      if (!status) return;
      var freeCard = document.querySelector('.plan-card:first-child');
      if (!freeCard) return;
      var badge = freeCard.querySelector('.plan-period');
      if (badge && !status.isSubscriber) {
        var remaining = Math.max(0, (status.freeLimit || 2) - (status.freeUsed || 0));
        badge.innerHTML = remaining + '/' + (status.freeLimit || 2) + ' remaining this month &middot; 本月剩余';
      }
      // If user is already a subscriber, highlight that
      if (status.isSubscriber) {
        var proCard = document.querySelector('.plan-card.featured');
        if (proCard) {
          var proBtn = proCard.querySelector('.plan-cta');
          if (proBtn) { proBtn.textContent = '已订阅 / Active'; proBtn.style.opacity = '0.7'; proBtn.style.pointerEvents = 'none'; }
        }
      }
    })
    .catch(function() { /* fail silently */ });

  // Checkout flow — call API to get checkout URL, then redirect
  document.querySelectorAll('.plan-cta[data-plan]').forEach(function(btn) {
    btn.addEventListener('click', function(e) {
      e.preventDefault();
      var plan = btn.getAttribute('data-plan');
      if (!plan) return;

      btn.style.opacity = '0.5';
      btn.style.pointerEvents = 'none';
      var origText = btn.textContent;
      btn.textContent = '跳转中... / Redirecting...';

      fetch('/api/payments/create-checkout-session', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json', 'x-user-id': uid },
        body: JSON.stringify({ plan: plan, uid: uid })
      })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        if (data.url) {
          window.location.href = data.url;
        } else {
          throw new Error(data.error || 'No checkout URL');
        }
      })
      .catch(function(err) {
        console.error('[checkout]', err);
        btn.textContent = origText;
        btn.style.opacity = '1';
        btn.style.pointerEvents = 'auto';
        alert('Checkout failed — please try again. 支付跳转失败，请重试。');
      });
    });
  });
})();
</script>

