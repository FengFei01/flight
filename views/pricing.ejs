    .faq-item { border-bottom: 1px solid var(--border); padding: 16px 0; }
    .faq-q { font-weight: 700; font-size: 13px; color: var(--text); margin-bottom: 6px; cursor: pointer; }
    .faq-a { font-size: 12px; color: var(--text2); line-height: 1.7; }

