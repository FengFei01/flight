    .trust-item { display: inline-flex; align-items: center; gap: 6px; color: var(--text2); font-size: 12px; padding: 6px 14px; background: rgba(255,255,255,0.03); border-radius: 4px; border: 1px solid rgba(255,255,255,0.06); }

